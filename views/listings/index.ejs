
<% layout("layouts/boilerplate") %>
<style>
    #filters{
        display:flex;
        flex-wrap:wrap;
        align-items: center;
        
    }
    .filter{
        margin:1rem;
        display:flex;
        flex-direction:column;
        align-items: center;
        opacity:0.7;
    }
    .filter:hover{
        opacity:1;
        cursor:pointer;
    }
    .filter p{
        font-size:0.8rem;
    }
    .toggler{
        border:1px solid;
        border-radius:1rem;
        height:3.3rem;
        padding:0.7rem;
        align-self: flex-start;
        margin:0.5rem 2rem;
       
    }
    .with-tax{
        display:none;
    }
    .without-tax{
        display:inline;
    }
</style>
<body> 
    <div id="filters">
        <div class="filter">
            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-bed"></i>
            <p>Rooms</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-city"></i>
            <p>Iconic Cities</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-mountain"></i>
            <p>Mountains</p>
        </div>
        <div class="filter">
            <i class="fa-brands fa-fort-awesome"></i>
            <p>Castles</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-person-swimming"></i>
            <p>Amazing Pools</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-tent"></i>
            <p>Camping</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-tractor"></i>
            <p>Farms</p>
        </div>
        <div class="filter">
            <i class="fa-regular fa-snowflake"></i>
            <p>Arctic</p>
        </div>

        <div class="toggler">
            <div class=" form-check form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Show prices after taxes</label>
            </div>
        </div>
        

    </div>
    
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
     <%for(listing of allListings) {%>
       <a href="/listings/<%=listing._id%>" class="listing-link">
        <div class="card listing-card col" style="width: 20rem;">
            <img src="<%=listing.image.url%>" class="card-img-top" alt="listing-img" style="height:20rem;">
              <div class="card-img-overlay"></div> <!--hover effect happening here-->
                <div class="card-body">
                    <p class="card-text"><b><%=listing.title%></b></p>
                    <p class="card-text"><%if(listing.price){%>
                        &#8377;
                        <span class="without-tax"> 
                            <%=listing.price.toLocaleString("en-IN")%>/night
                        </span>
                        <span class="with-tax"> 
                            <%=(listing.price+listing.price*18/100).toLocaleString("en-IN")%>/night
                        </span>
                         
                        <br><br>

                    <%}%></p>
                    
                </div>
                
        </div>
       </a>        
    <%}%>
    </div>
    
    <script>
        let taxSwitch=document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click",()=>{
            let infoWithTax=document.getElementsByClassName("with-tax");
            let infoWithoutTax=document.getElementsByClassName("without-tax");


             //hide price before tax
            for(info of infoWithoutTax){
                if(info.style.display!="none"){
                     info.style.display="none";
                }
                else{
                     info.style.display="inline";
                }
               
            }

            //show price after tax
            for(info of infoWithTax){
                if(info.style.display!="inline"){
                     info.style.display="inline";
                }
                else{
                     info.style.display="none";
                }
               
            }

           
        });
    </script>
</body>
